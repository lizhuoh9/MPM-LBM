        "wall_velocity_application_config_path": "configs/step36_wall_velocity_application_solid_vel_experimental.json"
      }
    },
    {
      "case": "solid_vel_with_static_boundary_motion",
      "kwargs": {
        "wall_velocity_application_mode": "solid_vel_experimental",
        "wall_velocity_application_config_path": "configs/step36_wall_velocity_application_solid_vel_experimental.json"
      }
    },
    {
      "case": "solid_vel_missing_application_config_path",
      "kwargs": {
        "boundary_motion_mode": "prescribed_kinematic",
        "boundary_motion_config_path": "configs/step34_boundary_motion_interface_prescribed_kinematic.json",
        "wall_velocity_application_mode": "solid_vel_experimental"
      }
    },
    {
      "case": "solid_vel_nonexistent_application_config_path",
      "kwargs": {
        "boundary_motion_mode": "prescribed_kinematic",
        "boundary_motion_config_path": "configs/step34_boundary_motion_interface_prescribed_kinematic.json",
        "wall_velocity_application_mode": "solid_vel_experimental",
        "wall_velocity_application_config_path": "configs/does_not_exist_wall_velocity_application.json"
      }
    }
  ]
}
